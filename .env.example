# Production: set in Vercel → Project → Settings → Environment Variables
# Use your real domain (https, no trailing slash)
NEXT_PUBLIC_SITE_URL=https://designbysanthosh.com

# Contact form (Resend). In production, verify your domain in Resend and set a branded from address.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=Portfolio Contact <contact@example.com>
